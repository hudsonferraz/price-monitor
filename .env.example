# Database (Neon, Supabase, or local PostgreSQL)
# After schema changes: run `npm run db:push` locally before deploying (Vercel/Render generate Prisma Client but do not update the DB)
DATABASE_URL=postgresql://user:password@localhost:5432/price_monitor

# Redis (Upstash — required for Poll now + scheduled polling)
REDIS_URL=rediss://default:password@your-db.upstash.io:6379

# Optional — worker health URL (used when you click Poll now to wake Render free tier)
WORKER_HEALTH_URL=https://price-monitor-worker.onrender.com/health

# Optional — secures /api/cron/wake-worker (Vercel Pro or manual curl only; Hobby plan cannot use crons)
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Keep the Render worker awake on free tier: use UptimeRobot to ping WORKER_HEALTH_URL every 5 minutes
# https://uptimerobot.com — see docs/render-deploy.md

# Auth.js / NextAuth (web app)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email alerts (worker — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=price-monitor <onboarding@resend.dev>
APP_URL=http://localhost:3000

# Worker — Facebook Marketplace scraping
FACEBOOK_STORAGE_STATE_PATH=facebook-storage-state.json
PLAYWRIGHT_HEADLESS=false
MOCK_MARKETPLACE=false
