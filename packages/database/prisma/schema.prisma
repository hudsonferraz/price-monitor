generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MarketplaceSource {
  FACEBOOK
}

enum PollRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                        String        @id @default(cuid())
  name                      String?
  email                     String        @unique
  emailVerified             DateTime?
  image                     String?
  emailNotificationsEnabled Boolean       @default(true)
  preferredLocale             String        @default("pt-BR")
  accounts                  Account[]
  sessions                  Session[]
  savedSearches             SavedSearch[]
  alerts                    Alert[]
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model SavedSearch {
  id              String        @id @default(cuid())
  userId          String
  name            String
  keywords        String
  minPriceCents   Int?
  maxPriceCents   Int?
  pollIntervalMin Int           @default(30)
  listingLimit    Int           @default(24)
  isEnabled       Boolean       @default(true)
  lastPolledAt    DateTime?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts          Alert[]
  pollRuns        PollRun[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([isEnabled, lastPolledAt])
}

model Listing {
  id         String            @id @default(cuid())
  source     MarketplaceSource
  externalId String
  title      String
  priceCents Int?
  currency   String            @default("BRL")
  url        String
  imageUrl   String?
  location   String?
  alerts     Alert[]
  snapshots  PollSnapshotListing[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([source, externalId])
}

model Alert {
  id            String      @id @default(cuid())
  userId        String
  savedSearchId String
  listingId     String
  emailSentAt   DateTime?
  previousPriceCents Int?
  priceDroppedAt     DateTime?
  seenAt             DateTime?
  dismissedAt        DateTime?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  listing       Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([savedSearchId, listingId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([savedSearchId, dismissedAt])
}

model PollSnapshotListing {
  id         String   @id @default(cuid())
  pollRunId  String
  listingId  String
  priceCents Int?
  pollRun    PollRun  @relation(fields: [pollRunId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([pollRunId, listingId])
  @@index([pollRunId])
}

model PollRun {
  id            String        @id @default(cuid())
  savedSearchId String
  status        PollRunStatus @default(PENDING)
  listingsFound Int           @default(0)
  newAlerts     Int           @default(0)
  errorMessage  String?
  durationMs    Int?
  startedAt     DateTime      @default(now())
  finishedAt    DateTime?
  savedSearch   SavedSearch           @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  snapshots     PollSnapshotListing[]

  @@index([savedSearchId, startedAt(sort: Desc)])
}
